{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "unified_exec",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/git-guard.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
