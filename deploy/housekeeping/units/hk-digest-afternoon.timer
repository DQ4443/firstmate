# Fires the afternoon digest at 16:00 America/Los_Angeles.
# Persistent=true catches up a missed run after the box was asleep at 16:00.
[Unit]
Description=Housekeeping FM afternoon digest timer (16:00 America/Los_Angeles)
Documentation=file:%h/firstmate/docs/housekeeping-intake.md

[Timer]
OnCalendar=*-*-* 16:00:00 America/Los_Angeles
Persistent=true
Unit=hk-digest@afternoon.service

[Install]
WantedBy=timers.target
