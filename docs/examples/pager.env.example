# config/pager.env.example - template for the off-box pager (bin/fm-pager.sh).
#
# Copy to config/pager.env (UNTRACKED - it holds tokens) and fill in. With no
# config/pager.env the pager is a clean no-op, so Phase 0 ships without requiring
# any of these accounts; wire them up to arm the dead-man's switch and paging.

# healthchecks.io ping URL. The poller curls this every cycle; if the poller or
# the whole box dies, the pings stop and healthchecks.io alarms you off-box.
FM_PAGER_HEALTHCHECK_URL=

# Pushover credentials. One push is sent when the headless drain dead-letters or
# an un-answered David message breaches its age SLA.
FM_PAGER_PUSHOVER_TOKEN=
FM_PAGER_PUSHOVER_USER=
